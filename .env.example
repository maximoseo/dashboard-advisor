# Dashboard Advisor — environment configuration.
# Copy to .env and fill in. NEVER commit the real .env.

PORT=3000

# --- Supabase ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_TABLE=suggestions

# --- GitHub (read access to the dashboard repos) ---
GITHUB_TOKEN=ghp_your_token

# --- Paperclip (local CLI) ---
PAPERCLIP_URL=http://localhost:4000
PAPERCLIP_TASK_PATH=/api/tasks
PAPERCLIP_COMPANY_ID=your-maximo-seo-company-id
PAPERCLIP_API_KEY=
PAPERCLIP_AGENT_CLAUDE=
PAPERCLIP_AGENT_CODEX=
PAPERCLIP_AGENT_DESIGNER=
PAPERCLIP_AGENT_PLANNER=
