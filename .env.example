# Dashboard Advisor — environment configuration.
# Copy to .env and fill in. NEVER commit the real .env.

PORT=3000

# --- Supabase (REST API, service role) ---
SUPABASE_URL=https://jzfamdshbfbwolupywrw.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_TABLE=dashboard_suggestions

# --- GitHub (read access to the dashboard repos) ---
GITHUB_TOKEN=ghp_your_token

# --- Paperclip (local CLI) ---
# Company/agent IDs default to Maximo SEO's in lib/config.js; override here only
# if they change. PAPERCLIP_API_KEY is the only secret and is required to call it.
PAPERCLIP_URL=http://127.0.0.1:3100
PAPERCLIP_TASK_PATH=/api/tasks
PAPERCLIP_COMPANY_ID=f0910fc4-92ca-48e9-847b-9523eff24cd5
PAPERCLIP_API_KEY=
PAPERCLIP_AGENT_CLAUDE=f43b18a1-5038-480c-b5a6-96359858510e
PAPERCLIP_AGENT_CODEX=3bec0bdc-8e12-4290-93d5-18d1e1b06992
PAPERCLIP_AGENT_DESIGNER=03964597-9f64-4fd2-a03b-68730fced757
PAPERCLIP_AGENT_PLANNER=11902ce6-7311-469e-b42a-b4a95c523329
